# Required for live OpenRouter (omit to use local echo mock for dev)
OPENROUTER_API_KEY=

# Default: openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: override API URL (default https://openrouter.ai/api/v1/chat/completions)
# OPENROUTER_BASE_URL=

# Optional: OpenRouter rankings / attribution (https://openrouter.ai/docs)
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_TITLE=DeOpenRouter

PORT=8787

# --- Periodic audit → Python audit-server → recordAudit on Anvil (optional) ---
# AUDIT_INTERVAL_MS=300000
# AUDIT_SERVER_URL=http://127.0.0.1:8765
# Base URL the audit probes (must expose /v1/chat/completions); default is this API
# AUDIT_RELAY_BASE_URL=http://127.0.0.1:8787
# AUDIT_PROVIDER_ID=0
# AUDIT_TIMEOUT_SEC=120
# CHAIN_RPC_URL=http://127.0.0.1:8545
# CHAIN_ID=31337
# Optional: POST canonical audit JSON; response = plain URI or JSON { uri, url, cid } (for on-chain URI)
# AUDIT_REPORT_PUBLISH_URL=https://your-pinning-service.example/upload
# MARKETPLACE_ADDRESS=0x...
# Same key as contract deployer by default (auditRecorder == deployer)
# AUDIT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
